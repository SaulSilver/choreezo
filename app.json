{
  "expo": {
    "name": "Choreezo",
    "slug": "choreezo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saulsilver.choreezo",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Choreezo does not use the camera.",
        "NSPhotoLibraryUsageDescription": "Choreezo does not access your photo library.",
        "NSMicrophoneUsageDescription": "Choreezo does not use the microphone.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.choreezo.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366F1",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "%(count)s chore updates"
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "00d2670e-3af9-4937-9c4e-8c4a34bc4264"
      }
    },
    "owner": "saulsilver"
  }
}
